{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug BOS executable",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/test/integration_test/localization_test2",
            "args": [
                "--camera_name=main_bot_left",
                "--image_folder=/bos/bos_logs/trimmed",
                "--speed=1"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build",
        }
    ]
}